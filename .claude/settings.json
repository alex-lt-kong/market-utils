{
  "permissions": {
    "allow": [
      "Bash(curl -fsSL https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.js -o /root/repos/monitors/pe_monitor/static/chart.umd.js)",
      "Bash(venv/bin/python -c ' *)",
      "Bash(venv/bin/pip install *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          { "type": "command", "command": "cat \"$CLAUDE_PROJECT_DIR/AGENTS.md\"" }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          { "type": "command", "command": "cat \"$CLAUDE_PROJECT_DIR/AGENTS.md\"" }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          { "type": "command", "command": "cat \"$CLAUDE_PROJECT_DIR/AGENTS.md\"" }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "cat \"$CLAUDE_PROJECT_DIR/AGENTS.md\"" }
        ]
      }
    ]
  }
}
